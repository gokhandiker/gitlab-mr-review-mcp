{
  "name": "gitlab-mr-review-mcp",
  "version": "2.0.0",
  "description": "MCP server for GitLab Merge Request reviews — 18 tools for reading diffs, posting comments, suggestions, approvals, CI inspection, code search, and more",
  "type": "module",
  "license": "MIT",
  "author": "Gokhan Diker",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gokhandiker/gitlab-mr-review-mcp.git"
  },
  "homepage": "https://github.com/gokhandiker/gitlab-mr-review-mcp#readme",
  "keywords": [
    "mcp",
    "gitlab",
    "merge-request",
    "code-review",
    "copilot",
    "ai",
    "model-context-protocol"
  ],
  "bin": {
    "gitlab-mr-review-mcp": "./build/index.js"
  },
  "scripts": {
    "build": "tsc && shx chmod +x build/index.js",
    "prepare": "npm run build",
    "start": "node build/index.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "@types/node": "^22.10.0",
    "typescript": "^5.7.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "shx": "^0.4.0",
    "vitest": "^3.1.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
